# Source from the Apex checkout before using the RVLLM Apex bridge.
#
# Example:
#   set -a
#   . rvllm/apex-rvllm.env.example
#   set +a
#   cd /Users/m5pro/git/solidsf/tools/rvllm
#   python3 -m rvllm_apex probe --apex-repo "$RVLLM_APEX_REPO" --dev "$RVLLM_APEX_DEV" --profile "$RVLLM_APEX_PROFILE"

RVLLM_APEX_REPO=/Users/m5pro/git/unified-engine
RVLLM_APEX_DEV=xdma0
RVLLM_APEX_PROFILE=kintex7
RVLLM_APEX_BASE_ADDR=0x02000000
